{
  "name": "pi-simplify-code",
  "version": "0.1.0",
  "description": "Auto-trigger code simplification prompts after code edits in pi.",
  "type": "module",
  "main": "./dist/index.js",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "prompt",
    "refactor"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:coverage": "vitest run --config vitest.config.unit.ts --coverage"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.3.0",
    "@mariozechner/pi-coding-agent": "*",
    "@vitest/coverage-v8": "^3.2.4",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
